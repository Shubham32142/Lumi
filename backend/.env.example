# Copy to .env.local and fill in.

# MongoDB Atlas connection string (cluster URL — leave the database name OUT of the
# path; it's set separately below so it works even with a bare Atlas SRV string)
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority"

# Database name to use within the cluster
MONGODB_DB="lumi"

# JWT signing secret (use a long random string)
JWT_SECRET="change-me-to-a-long-random-secret"
