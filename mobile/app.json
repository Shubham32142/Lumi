{
  "expo": {
    "name": "Lumi",
    "slug": "lumi",
    "scheme": "lumi",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumiapp.mobile"
    },
    "android": {
      "package": "com.lumiapp.mobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E0668E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#E0668E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://lumi-xbka.vercel.app"
    }
  }
}
